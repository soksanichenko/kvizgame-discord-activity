location = /discord-bot/health {
    auth_basic "Restricted";
    auth_basic_user_file {{ nginx_confd_path }}/meow-bot-health.htpasswd;
    proxy_pass            http://discord-meow-bot:{{ health_port }}/health;
    proxy_read_timeout    5s;
    proxy_connect_timeout 3s;
}

location /kvizgame/ {
    proxy_pass         http://discord-meow-bot:{{ kvizgame_port }}/;
    proxy_http_version 1.1;
    proxy_set_header   Host       $host;
    proxy_set_header   X-Real-IP  $remote_addr;
}

location ~ ^/(token|sessions|media|ws)(/|$) {
    proxy_pass         http://discord-meow-bot:{{ kvizgame_port }};
    proxy_http_version 1.1;
    proxy_set_header   Upgrade    $http_upgrade;
    proxy_set_header   Connection "upgrade";
    proxy_set_header   Host       $host;
    proxy_set_header   X-Real-IP  $remote_addr;
    proxy_read_timeout 3600;
}
