# Discord proxy prepends the Root URL path (/kvizgame) to every asset request,
# so /kvizgame/assets/... becomes /kvizgame/kvizgame/assets/... on our server.
# These regex locations catch the doubled path and enforce correct MIME types.
location ~* ^/kvizgame/kvizgame/assets/[^/]+\.(js|mjs)$ {
    resolver           127.0.0.11 valid=10s;
    set $kvizgame      kvizgame:{{ kvizgame_port }};
    rewrite            ^/kvizgame/kvizgame(/assets/.+)$ $1 break;
    proxy_pass         http://$kvizgame;
    proxy_http_version 1.1;
    proxy_set_header   Host      $host;
    proxy_set_header   X-Real-IP $remote_addr;
    proxy_hide_header  Content-Type;
    add_header         Content-Type "application/javascript; charset=utf-8" always;
}

location ~* ^/kvizgame/kvizgame/assets/[^/]+\.css$ {
    resolver           127.0.0.11 valid=10s;
    set $kvizgame      kvizgame:{{ kvizgame_port }};
    rewrite            ^/kvizgame/kvizgame(/assets/.+)$ $1 break;
    proxy_pass         http://$kvizgame;
    proxy_http_version 1.1;
    proxy_set_header   Host      $host;
    proxy_set_header   X-Real-IP $remote_addr;
    proxy_hide_header  Content-Type;
    add_header         Content-Type "text/css; charset=utf-8" always;
}

location /kvizgame/kvizgame/assets/ {
    resolver           127.0.0.11 valid=10s;
    set $kvizgame      kvizgame:{{ kvizgame_port }};
    proxy_pass         http://$kvizgame/assets/;
    proxy_http_version 1.1;
    proxy_set_header   Host      $host;
    proxy_set_header   X-Real-IP $remote_addr;
}

location /kvizgame/ {
    resolver           127.0.0.11 valid=10s;
    set $kvizgame      kvizgame:{{ kvizgame_port }};
    proxy_pass         http://$kvizgame/;
    proxy_http_version 1.1;
    proxy_set_header   Host      $host;
    proxy_set_header   X-Real-IP $remote_addr;
}

location /api/ {
    resolver           127.0.0.11 valid=10s;
    set $kvizgame      kvizgame:{{ kvizgame_port }};
    proxy_pass         http://$kvizgame/;
    proxy_http_version 1.1;
    proxy_set_header   Upgrade    $http_upgrade;
    proxy_set_header   Connection "upgrade";
    proxy_set_header   Host       $host;
    proxy_set_header   X-Real-IP  $remote_addr;
    proxy_read_timeout 3600;
}
